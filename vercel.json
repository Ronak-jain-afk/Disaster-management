{
  "buildCommand": "cd server && npm run build",
  "outputDirectory": "server/dist",
  "installCommand": "cd server && npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
